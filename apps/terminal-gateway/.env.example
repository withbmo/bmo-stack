# Port for the terminal gateway HTTP/WebSocket server
PORT=3403

# Secret used to verify JWT session tokens issued by the API.
# Must match ENV_SESSION_SECRET in the API service.
ENV_SESSION_SECRET=

# Alternative name for the same secret (either one is accepted).
JWT_SECRET=

# AWS region is NOT required here — terminal-gateway creates a regional SSMClient
# per connection using the 'region' claim from the JWT. The ECS task role
# (demo-terminal-task-role with AmazonSSMFullAccess) provides AWS credentials
# automatically via the container metadata endpoint.
#
# For local development, set your AWS credentials via the normal SDK chain:
#   AWS_PROFILE=your-profile
# or
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...
#   AWS_REGION=us-east-1
