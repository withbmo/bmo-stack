# ============================================================================
# API Configuration
# ============================================================================
# NODE_ENV (development | production) is set by Next.js and drives API URL selection below.

# Primary API URL (takes priority if set)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Environment-specific API URLs (fallback if NEXT_PUBLIC_API_URL is not set)
NEXT_PUBLIC_API_URL_DEV=http://localhost:3001
NEXT_PUBLIC_API_URL_PROD=https://api.pytholit.com

# ============================================================================
# Novu Notifications
# ============================================================================
NEXT_PUBLIC_NOVU_APP_ID=your-novu-app-id
NEXT_PUBLIC_NOVU_API_URL=https://api.novu.co
NEXT_PUBLIC_NOVU_WS_URL=wss://ws.novu.co

# ============================================================================
# Optional: Analytics & Monitoring
# ============================================================================
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# ============================================================================
# Optional: Feature Flags
# ============================================================================
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
