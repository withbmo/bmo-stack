# Port for the ingress router HTTP server
PORT=3402

# Shared secret used to validate proxy session tokens from internal services.
# Keep this aligned with the API and terminal gateway in local development.
ENV_SESSION_SECRET=your-local-session-secret

# Alternative name for the same secret (either one is accepted).
JWT_SECRET=

# Comma-separated SHA-256 hashes for trusted API keys used by service-to-service callers.
# Leave empty in local development unless you need API-key-based ingress access.
PYTHOLIT_PROXY_API_KEY_HASHES=

