# Local development for env-orchestrator
#
# Copy to `apps/env-orchestrator/.env` (optional) and run:
#   pnpm --filter @pytholit/env-orchestrator dev
#
# NOTE: These must match the API (apps/api/.env):
# - INTERNAL_SECRET must be identical (API <-> orchestrator)
# - API_URL must point to the running API for status callbacks

PORT=3003
API_URL=http://localhost:3001
INTERNAL_SECRET=dev-internal-secret
REDIS_URL=redis://localhost:6379

# AWS credentials are taken from your shell/SDK chain (AWS_PROFILE, AWS_ACCESS_KEY_ID, etc.)
# Example:
# AWS_PROFILE=default
