# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=development
PORT=3001

# ============================================================================
# Frontend URL (for CORS)
# ============================================================================
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/pytholit_dev

# ============================================================================
# Redis (Optional - for OAuth state store across instances)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# JWT Authentication
# ============================================================================
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=1h

# ============================================================================
# OAuth - Google
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/oauth/google/callback

# ============================================================================
# OAuth - GitHub
# ============================================================================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/oauth/github/callback

# ============================================================================
# Stripe (Billing)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# Email Service (Optional)
# ============================================================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@example.com
# EMAIL_PASSWORD=your-email-password
# EMAIL_FROM=noreply@pytholit.com

# ============================================================================
# Novu (Notifications - Optional)
# ============================================================================
# NOVU_API_KEY=your-novu-api-key
# NOVU_APP_ID=your-novu-app-id
