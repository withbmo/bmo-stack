# ============================================================================
# Server Configuration
# ============================================================================
# Application environment selector (optional; if missing, the API infers from FRONTEND_URL / NODE_ENV).
# Values: localhost | development | production
APP_ENV=localhost

NODE_ENV=development
PORT=3001

# ============================================================================
# Frontend URL (for CORS)
# ============================================================================
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/pytholit_dev

# ============================================================================
# Redis (OAuth State & Code Storage)
# ============================================================================
# Production: Managed by AWS ElastiCache (REDIS_URL injected by ECS)
# Development: Optional - leave empty to use in-memory fallback
#
# When to use Redis:
#   - Multi-instance deployments (required for horizontal scaling)
#   - Production environments (AWS ElastiCache)
#   - Testing OAuth flows across server restarts
#
# When in-memory is fine:
#   - Local development (single instance)
#   - No Redis available (automatic fallback with warning log)
#
# Local Redis (optional):
#   Install: brew install redis (macOS) or docker run -p 6379:6379 redis
#   Then set: REDIS_URL=redis://localhost:6379
#
# Production (AWS ElastiCache):
#   Format: redis://pytholit-demo-redis.xxxxxx.cache.amazonaws.com:6379
#   Auto-injected by ECS from Terraform outputs
#
REDIS_URL=

# ============================================================================
# JWT Authentication
# ============================================================================
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=1h

# ============================================================================
# OAuth - Google
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/oauth/google/callback

# ============================================================================
# OAuth - GitHub
# ============================================================================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/oauth/github/callback

# ============================================================================
# Stripe (Billing)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# ZeptoMail (Transactional Email Service)
# ============================================================================
# Production: Managed via AWS Secrets Manager (ZEPTOMAIL_API_KEY injected by ECS)
# Development: Get your API key from: https://mailadmin.zoho.com/zeptomail/
#
# If ZEPTOMAIL_API_KEY is empty, email service runs in dev mode (console logging only)
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_BASE_URL=https://api.zeptomail.com
ZEPTOMAIL_FROM_EMAIL=noreply@pytholit.dev
ZEPTOMAIL_FROM_NAME=Pytholit

# ============================================================================
# Novu (Notifications - Optional)
# ============================================================================
# NOVU_API_KEY=your-novu-api-key
# NOVU_APP_ID=your-novu-app-id
