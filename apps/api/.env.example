# ============================================================================
# Server
# ============================================================================
# development | production. Drives CORS, auth strictness, and DB/secret requirements.
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
# Cross-subdomain cookie domain (e.g. .pytholit.dev). Leave empty for localhost.
COOKIE_DOMAIN=

# Public API URL — root URL where this API is served. Used for:
# - Better Auth baseURL (OAuth callbacks, email verification links). Set this to avoid "Base URL could not be determined" warning.
# - OAuth callback URL fallback when GITHUB_CALLBACK_URL / GOOGLE_CALLBACK_URL not set.
# - localhost: http://localhost:3001 (or leave empty to use that default)
# - development: e.g. https://api.dev.pytholit.dev
# - production: set by infra (e.g. https://api.pytholit.dev)
API_URL=http://localhost:3001

# ============================================================================
# Database (connection built from these; DATABASE_URL is not used)
# ============================================================================
# Point these at your local PostgreSQL instance.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your-db-name
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_SSLMODE=disable
# Optional: use only if migrations should bypass the runtime DB host (for example Supabase direct host)
DB_DIRECT_HOST=
DB_DIRECT_PORT=

# ============================================================================
# Redis (Better Auth Sessions & OAuth State)
# ============================================================================
# Production: Managed by AWS ElastiCache (REDIS_URL injected by ECS)
# Development: Optional - leave empty for in-memory session storage
#
# Better Auth uses Redis for:
#   - Session storage across multiple API instances
#   - OAuth state management (CSRF protection)
#
# When to use Redis:
#   - Multi-instance deployments (required for horizontal scaling)
#   - Production environments (AWS ElastiCache)
#   - Persistent sessions across server restarts
#
# When in-memory is fine:
#   - Local development (single instance)
#   - No Redis available (automatic fallback)
#
# Local Redis (optional):
#   Install: brew install redis (macOS) or docker run -p 6379:6379 redis
#   Then set: REDIS_URL=redis://localhost:6379
#
# Production (AWS ElastiCache):
#   Format: redis://pytholit-demo-redis.xxxxxx.cache.amazonaws.com:6379
#   Auto-injected by ECS from Terraform outputs
#
REDIS_URL=

# ============================================================================
# Environment Orchestrator (EC2 provisioning)
# ============================================================================
# URL of the env-orchestrator service (local dev default)
ORCHESTRATOR_URL=http://localhost:3003
#
# Shared secret used to secure internal API<->orchestrator routes.
# Must match between API and env-orchestrator.
INTERNAL_SECRET=your-internal-service-secret

# ============================================================================
# Authentication (Better Auth)
# ============================================================================
# Secret key for Better Auth session encryption and JWT signing. Change in production.
JWT_SECRET=your-jwt-signing-secret
JWT_EXPIRES_IN=1h
# Optional one-time bootstrap: if no admins exist, this email is granted owner access.
INITIAL_ADMIN_EMAIL=

# ============================================================================
# Cloudflare Turnstile (bot protection)
# ============================================================================
# Get keys from https://dash.cloudflare.com/. Use test keys for development.
TURNSTILE_SECRET_KEY=

# ============================================================================
# OAuth - Google
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Note: Better Auth auto-generates callback URLs based on API_URL
# Callback URL format: {API_URL}/api/v1/auth/callback/google
# For local dev: http://localhost:3001/api/v1/auth/callback/google

# ============================================================================
# OAuth - GitHub
# ============================================================================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# Note: Better Auth auto-generates callback URLs based on API_URL
# Callback URL format: {API_URL}/api/v1/auth/callback/github
# For local dev: http://localhost:3001/api/v1/auth/callback/github

# ============================================================================
# Email (SMTP + queued delivery)
# ============================================================================
# Required for non-development environments:
#   - SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
#   - REDIS_URL (queue delivery)
#
# Recommended defaults for sender identity:
EMAIL_FROM_ADDRESS=noreply@pytholit.dev
EMAIL_FROM_NAME=Pytholit
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
#
# Optional in non-production to avoid accidental sends:
#   EMAIL_ALLOWED_DOMAINS=example.com,internal.dev
#   EMAIL_BLOCKED_DOMAINS=gmail.com,yahoo.com
EMAIL_ALLOWED_DOMAINS=
EMAIL_BLOCKED_DOMAINS=
#
# Queue tuning (optional)
EMAIL_QUEUE_CONCURRENCY=5
EMAIL_QUEUE_RATE_LIMIT_MAX=50
EMAIL_QUEUE_RATE_LIMIT_DURATION_MS=1000
EMAIL_QUEUE_REMOVE_ON_COMPLETE=1000
EMAIL_QUEUE_REMOVE_ON_FAIL=5000

# ============================================================================
# Storage (S3-compatible object storage for avatars)
# ============================================================================
# Driver: 'local' (filesystem fallback) or 's3' (recommended for production)
STORAGE_DRIVER=local
#
# For production (AWS S3):
#   STORAGE_DRIVER=s3
#   S3_BUCKET, S3_REGION, S3_PUBLIC_URL are injected by Terraform via ECS env vars.
#   AWS credentials come from the ECS task IAM role (no keys needed).
#
S3_BUCKET=
S3_REGION=us-east-1
# MinIO dev endpoint — leave empty for real AWS S3
S3_ENDPOINT=
# Access key — leave empty to use ECS task role (production)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL for serving objects (e.g. https://<bucket>.s3.<region>.amazonaws.com)
S3_PUBLIC_URL=
# Required for MinIO (path-style URLs); set false for AWS S3
S3_FORCE_PATH_STYLE=false
