# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=development
PORT=3001

# ============================================================================
# Frontend URL (for CORS)
# ============================================================================
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/pytholit_dev

# ============================================================================
# Redis (Optional - for OAuth state store across instances)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# JWT Authentication
# ============================================================================
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=1h

# ============================================================================
# OAuth - Google
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/oauth/google/callback

# ============================================================================
# OAuth - GitHub
# ============================================================================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/oauth/github/callback

# ============================================================================
# Stripe (Billing)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# ZeptoMail (Transactional Email Service)
# ============================================================================
# Production: Managed via AWS Secrets Manager (ZEPTOMAIL_API_KEY injected by ECS)
# Development: Get your API key from: https://mailadmin.zoho.com/zeptomail/
#
# If ZEPTOMAIL_API_KEY is empty, email service runs in dev mode (console logging only)
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_BASE_URL=https://api.zeptomail.com
ZEPTOMAIL_FROM_EMAIL=noreply@pytholit.dev
ZEPTOMAIL_FROM_NAME=Pytholit

# ============================================================================
# Novu (Notifications - Optional)
# ============================================================================
# NOVU_API_KEY=your-novu-api-key
# NOVU_APP_ID=your-novu-app-id
