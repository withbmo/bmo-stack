# ============================================================================
# Server Configuration
# ============================================================================
# Application environment selector (optional; if missing, the API infers from FRONTEND_URL / NODE_ENV).
# Values: localhost | development | production
APP_ENV=localhost

NODE_ENV=development
PORT=3001

# ============================================================================
# Frontend URL (for CORS)
# ============================================================================
FRONTEND_URL=http://localhost:3000

# Public API URL (for OAuth callback URL fallback when GITHUB_CALLBACK_URL / GOOGLE_CALLBACK_URL not set).
# - localhost: leave empty (uses http://localhost:PORT)
# - development: e.g. https://api.dev.pytholit.dev
# - production: set by infra (or e.g. https://api.pytholit.dev)
API_URL=

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/pytholit_dev

# ============================================================================
# Redis (Better Auth Sessions & OAuth State)
# ============================================================================
# Production: Managed by AWS ElastiCache (REDIS_URL injected by ECS)
# Development: Optional - leave empty for in-memory session storage
#
# Better Auth uses Redis for:
#   - Session storage across multiple API instances
#   - OAuth state management (CSRF protection)
#
# When to use Redis:
#   - Multi-instance deployments (required for horizontal scaling)
#   - Production environments (AWS ElastiCache)
#   - Persistent sessions across server restarts
#
# When in-memory is fine:
#   - Local development (single instance)
#   - No Redis available (automatic fallback)
#
# Local Redis (optional):
#   Install: brew install redis (macOS) or docker run -p 6379:6379 redis
#   Then set: REDIS_URL=redis://localhost:6379
#
# Production (AWS ElastiCache):
#   Format: redis://pytholit-demo-redis.xxxxxx.cache.amazonaws.com:6379
#   Auto-injected by ECS from Terraform outputs
#
REDIS_URL=

# ============================================================================
# Environment Orchestrator (EC2 provisioning)
# ============================================================================
# URL of the env-orchestrator service (local dev default)
ORCHESTRATOR_URL=http://localhost:3003
#
# Shared secret used to secure internal API<->orchestrator routes.
# Must match between API and env-orchestrator.
INTERNAL_SECRET=dev-internal-secret

# ============================================================================
# Authentication (Better Auth)
# ============================================================================
# Secret key for Better Auth session encryption and JWT signing
# IMPORTANT: Change this in production to a strong random value
JWT_SECRET=your-secret-key-change-this-in-production
# Optional one-time bootstrap: if no admins exist, this email is granted owner access.
INITIAL_ADMIN_EMAIL=

# ============================================================================
# OAuth - Google
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Note: Better Auth auto-generates callback URLs based on API_URL
# Callback URL format: {API_URL}/api/v1/auth/callback/google
# For local dev: http://localhost:3001/api/v1/auth/callback/google

# ============================================================================
# OAuth - GitHub
# ============================================================================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# Note: Better Auth auto-generates callback URLs based on API_URL
# Callback URL format: {API_URL}/api/v1/auth/callback/github
# For local dev: http://localhost:3001/api/v1/auth/callback/github

# ============================================================================
# Stripe (Billing)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# Lago (Billing Infrastructure)
# ============================================================================
LAGO_API_URL=http://localhost:3002
LAGO_API_KEY=
LAGO_WEBHOOK_SECRET=
LAGO_ORGANIZATION_ID=
LAGO_ROLLOUT_PERCENT=0

# ============================================================================
# Email (SMTP + queued delivery)
# ============================================================================
# Required for non-development environments:
#   - SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
#   - REDIS_URL (queue delivery)
#
# Recommended defaults for sender identity:
EMAIL_FROM_ADDRESS=noreply@pytholit.dev
EMAIL_FROM_NAME=Pytholit
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
#
# Optional in non-production to avoid accidental sends:
#   EMAIL_ALLOWED_DOMAINS=example.com,internal.dev
#   EMAIL_BLOCKED_DOMAINS=gmail.com,yahoo.com
EMAIL_ALLOWED_DOMAINS=
EMAIL_BLOCKED_DOMAINS=
#
# Queue tuning (optional)
EMAIL_QUEUE_CONCURRENCY=5
EMAIL_QUEUE_RATE_LIMIT_MAX=50
EMAIL_QUEUE_RATE_LIMIT_DURATION_MS=1000
EMAIL_QUEUE_REMOVE_ON_COMPLETE=1000
EMAIL_QUEUE_REMOVE_ON_FAIL=5000

# ============================================================================
# Novu (Notifications - Optional)
# ============================================================================
# NOVU_API_KEY=your-novu-api-key
# NOVU_APP_ID=your-novu-app-id
NOVU_SUBSCRIBER_HASH_SECRET=