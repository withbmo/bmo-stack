    "@better-auth/core": "^1.5.5",
    "@better-auth/infra": "^0.1.12",
    "@casl/ability": "^6.8.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
