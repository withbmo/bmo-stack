    "react-dom": "^19.2.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "stripe": "^20.3.1",
    "uuid": "^11.0.5",
    "validator": "^13.15.26",
    "yesql": "^7.0.0",
    "zod": "^4.3.6"
