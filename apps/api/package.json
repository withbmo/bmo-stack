{
  "name": "@pytholit/api",
  "version": "2.0.0",
  "description": "Pytholit Nest.js API",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@better-auth/core": "^1.5.5",
    "@better-auth/infra": "^0.1.12",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/throttler": "^6.5.0",
    "@pytholit/contracts": "workspace:*",
    "@pytholit/db": "workspace:*",
    "@pytholit/project-spec": "workspace:*",
    "@pytholit/validation": "workspace:*",
    "@sesamecare-oss/redlock": "^1.4.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@thallesp/nestjs-better-auth": "^2.5.1",
    "better-auth": "^1.5.5",
    "bullmq": "^5.69.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "envalid": "^8.0.0",
    "express": "^4.21.2",
    "file-type": "^21.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "kysely": "^0.28.11",
    "nestjs-cls": "^6.2.0",
    "pg": "^8.18.0",
    "rate-limiter-flexible": "^10.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.1",
    "@nestjs/testing": "^11.1.13",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "tsx"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/test"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)sx?$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
