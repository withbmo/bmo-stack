// Pytholit database schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Auth and users
// ============================================================================

model User {
  id              String  @id @default(uuid())
  email           String  @unique
  username        String? @unique
  firstName       String? @map("first_name")
  lastName        String? @map("last_name")
  bio             String?
  avatarUrl       String? @map("avatar_url")
  hashedPassword  String? @map("hashed_password")

  isActive        Boolean @default(true) @map("is_active")
  isEmailVerified Boolean @default(false) @map("is_email_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects   Project[]
  deployJobs DeployJob[]
  sessions   Session[]
  accounts   Account[]

  @@map("users")
}

/// Better Auth session records resolved by the global auth guard via `auth.api.getSession`.
model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Better Auth provider accounts, including OAuth tokens and onboarding flags.
model Account {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  accountId    String    @map("account_id")
  providerId   String    @map("provider_id")
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  idToken      String?   @map("id_token")
  scope        String?
  password     String?
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  expiresAt    DateTime? @map("expires_at")
  oauthOnboardingRequired Boolean  @default(false) @map("oauth_onboarding_required")
  oauthOnboardingCompletedAt DateTime? @map("oauth_onboarding_completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

/// Better Auth verification records used for email verification and password reset flows.
model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String   @unique
  expiresAt  DateTime @map("expiresAt")
  createdAt  DateTime @default(now()) @map("createdAt")
  updatedAt  DateTime @updatedAt @map("updatedAt")

  @@unique([identifier, value])
  @@map("verification")
}

// ============================================================================
// Projects
// ============================================================================

/// User-owned project metadata used by project CRUD and deploy-job ownership checks.
model Project {
  id                String   @id @default(uuid())
  ownerId           String   @map("owner_id")
  name              String
  slug              String
  repoExportEnabled Boolean  @default(false) @map("repo_export_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deployJobs   DeployJob[]

  @@unique([ownerId, slug])
  @@map("projects")
}

// ============================================================================
// Deployments
// ============================================================================

enum DeployJobStatus {
  queued
  running
  succeeded
  failed
  canceled
}

/// Deployment job state returned by the deploy-jobs API and rendered by the web dashboard.
model DeployJob {
  id                    String          @id @default(uuid())
  projectId             String          @map("project_id")
  triggeredByUserId     String?         @map("triggered_by_user_id")
  status                DeployJobStatus @default(queued)
  currentStep           String?         @map("current_step")
  steps                 Json
  source                Json
  createdAt             DateTime        @default(now()) @map("created_at")
  startedAt             DateTime?       @map("started_at")
  finishedAt            DateTime?       @map("finished_at")

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy User?       @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@map("deploy_jobs")
}
