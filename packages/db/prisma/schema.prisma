// Pytholit Database Schema
// Converted from SQLAlchemy models to Prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// User & Authentication
// ============================================================================

enum AdminLevel {
  owner
  operator
  viewer
}

enum SignupBonusStatus {
  PENDING
  GRANTED
  FAILED
}

model User {
  id              String  @id @default(uuid())
  email           String  @unique
  username        String  @unique
  displayUsername String? @map("display_username")
  firstName       String? @map("first_name")
  lastName        String? @map("last_name")
  bio             String?
  avatarUrl       String? @map("avatar_url")
  hashedPassword  String? @map("hashed_password")

  // Status flags
  isActive        Boolean @default(true) @map("is_active")
  isEmailVerified Boolean @default(false) @map("is_email_verified")

  // External service IDs
  signupBonusGrantedAt DateTime?         @map("signup_bonus_granted_at")
  signupBonusStatus    SignupBonusStatus @default(PENDING) @map("signup_bonus_status")
  novuSubscriberId     String?           @unique @map("novu_subscriber_id")
  stripeCustomerId     String?           @unique @map("stripe_customer_id")

  // Universal ID used to identify the user in Lago/Orb billing engine
  billingProviderId    String?           @unique @map("billing_provider_id")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  projects      Project[]
  environments  Environment[]
  deployJobs    DeployJob[]
  wizardBuilds            WizardBuild[]
  oauthAccounts           OAuthAccount[]
  sessions                Session[]
  accounts                Account[]
  billingAccount          BillingAccount?
  billingEngineState      BillingEngineState?

  auditLogs               AuditLog[]
  adminMembership         Admin?               @relation("AdminMembership")
  grantedAdminMemberships Admin[]              @relation("AdminGrantedBy")

  @@map("users")
}

model Admin {
  id              String     @id @default(uuid())
  userId          String     @unique @map("user_id")
  level           AdminLevel
  grantedByUserId String?    @map("granted_by_user_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user      User  @relation("AdminMembership", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("AdminGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@index([level])
  @@index([grantedByUserId])
  @@map("admins")
}

model OAuthAccount {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  provider     String // google, github
  accountId    String    @map("account_id")
  accountEmail String?   @map("account_email")
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, accountId])
  @@map("oauth_accounts")
}

// Better Auth session management
model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// Better Auth account table (replaces OAuthAccount for Better Auth)
model Account {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  accountId    String    @map("account_id")
  providerId   String    @map("provider_id") // "google" | "github" | "credentials"
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

// Better Auth verification table (email verification, password reset)
// Note: This table is auto-managed by Better Auth
model Verification {
  id         String   @id @default(uuid())
  identifier String // email or phone
  value      String   @unique // token/value
  expiresAt  DateTime @map("expiresAt")
  createdAt  DateTime @default(now()) @map("createdAt")
  updatedAt  DateTime @updatedAt @map("updatedAt")

  @@unique([identifier, value])
  @@map("verification")
}

model AuthLoginAttempt {
  id             String    @id @default(uuid())
  email          String    @unique
  failedAttempts Int       @default(0) @map("failed_attempts")
  firstFailedAt  DateTime? @map("first_failed_at")
  lastFailedAt   DateTime? @map("last_failed_at")
  lockedUntil    DateTime? @map("locked_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([lockedUntil])
  @@map("auth_login_attempts")
}

model AuthOtpThrottle {
  id          String    @id @default(uuid())
  email       String
  ip          String
  action      String
  windowStart DateTime  @map("window_start")
  windowSec   Int       @map("window_sec")
  attempts    Int       @default(0)
  lockedUntil DateTime? @map("locked_until")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([email, ip, action, windowStart, windowSec])
  @@index([email, ip, action, lockedUntil])
  @@map("auth_otp_throttles")
}

// ============================================================================
// Projects & Environments
// ============================================================================

model Project {
  id                String   @id @default(uuid())
  ownerId           String   @map("owner_id")
  name              String
  slug              String
  repoExportEnabled Boolean  @default(false) @map("repo_export_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deployJobs   DeployJob[]
  wizardBuilds WizardBuild[]

  @@unique([ownerId, slug])
  @@map("projects")
}

model Environment {
  id            String   @id @default(uuid())
  ownerId       String   @map("owner_id")
  projectId     String?  @map("project_id") // Nullable for backward compatibility
  envType       String   @map("name") // dev, staging, prod
  displayName   String   @map("display_name")
  tierPolicy    String   @default("free") @map("tier_policy") // free, pro, enterprise
  executionMode String   @default("managed") @map("execution_mode") // managed, byo_aws
  region        String   @default("us-east-1")
  visibility    String   @default("private") // public, private
  config        Json? // Environment configuration (JSONB)
  orchestratorStatus          String   @default("unknown") @map("orchestrator_status")
  orchestratorStatusUpdatedAt DateTime @default(now()) @map("orchestrator_status_updated_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deployJobs DeployJob[]

  @@unique([ownerId, displayName])
  @@map("environments")
}

model OrchestratorRegionConfig {
  id                  String   @id @default(uuid())
  region              String   @unique
  subnetIds           String[] @map("subnet_ids")
  securityGroupIds    String[] @map("security_group_ids")
  amiIdX86_64         String   @map("ami_id_x86_64")
  amiIdArm64          String   @map("ami_id_arm64")
  instanceProfileName String   @map("instance_profile_name")
  userDataBase64      String?  @map("user_data_base64")
  dynamodbTable       String   @default("EnvRouting") @map("dynamodb_table")
  envDomainSuffix     String   @default("envs.pytholit.dev") @map("env_domain_suffix")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("orchestrator_region_configs")
}

// ============================================================================
// Deployments
// ============================================================================

enum DeployJobStatus {
  queued
  running
  succeeded
  failed
  canceled
}

model DeployJob {
  id                    String          @id @default(uuid())
  projectId             String          @map("project_id")
  environmentId         String          @map("environment_id")
  triggeredByUserId     String?         @map("triggered_by_user_id")
  status                DeployJobStatus @default(queued)
  currentStep           String?         @map("current_step")
  steps                 Json // Array of deployment steps (JSONB)
  source                Json // Deployment source info (git, upload, template)
  executionModeSnapshot String          @map("execution_mode_snapshot")
  createdAt             DateTime        @default(now()) @map("created_at")
  startedAt             DateTime?       @map("started_at")
  finishedAt            DateTime?       @map("finished_at")

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  triggeredBy User?       @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@map("deploy_jobs")
}

// ============================================================================
// Wizard (Project generation)
// ============================================================================

model WizardBuild {
  id        String @id @default(uuid())
  ownerId   String @map("owner_id")
  projectId String @map("project_id")
  version   String // Wizard blueprint version (e.g. 2026.02.08)

  inputs   Json // Raw + default-applied inputs used to generate
  manifest Json // WizardManifest (files, metadata)
  lock     Json? // Optional BlueprintLock (debug/audit)

  createdAt DateTime @default(now()) @map("created_at")

  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([projectId])
  @@map("wizard_builds")
}

// ============================================================================
// Billing — Stripe subscriptions, webhook persistence, and access state snapshots
// ============================================================================

enum BillingAccountType {
  user
}

enum PlanId {
  free
  pro
  max
}

enum BillingInterval {
  month
  year
}

enum SubscriptionStatus {
  active
  trialing
  incomplete
  incomplete_expired
  past_due
  unpaid
  paused
  canceled
  processing_upgrade
}

enum FeatureAccessState {
  enabled
  locked_due_to_payment
  locked_no_subscription
}

enum StripeWebhookProcessingStatus {
  received
  queued
  processed
  failed
}

enum BillingEngineProvider {
  stripe
  lago
  orb
}

enum BillingEngineAccessState {
  enabled
  locked_due_to_payment
  locked_wallet_depleted
  locked_no_subscription
}

enum EngineWebhookProcessingStatus {
  received
  queued
  processed
  failed
}

model BillingAccount {
  id          String             @id @default(uuid())
  ownerUserId String             @unique @map("owner_user_id")
  type        BillingAccountType @default(user)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  ownerUser     User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@map("billing_accounts")
}

model StripeWebhookEvent {
  stripeEventId      String                     @id @map("stripe_event_id")
  eventType          String                     @map("event_type")
  payloadJson        Json                       @map("payload_json")
  rawBody            Bytes                      @map("raw_body")
  signatureHeader    String                     @map("signature_header")
  processingStatus   StripeWebhookProcessingStatus @default(received) @map("processing_status")
  processingAttempts Int                        @default(0) @map("processing_attempts")
  lastError          String?                    @map("last_error")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")

  @@index([processingStatus, createdAt])
  @@map("stripe_webhook_events")
}

model BillingEngineState {
  userId                 String                   @id @map("user_id")
  provider               BillingEngineProvider
  externalCustomerId     String                   @unique @map("external_customer_id")
  engineSubscriptionExternalId String             @unique @map("engine_subscription_external_id")
  planCode               String                   @map("plan_code")
  planCatalogVersion     Int?                     @map("plan_catalog_version")
  accessState            BillingEngineAccessState @map("access_state")
  lockedReason           String?                  @map("locked_reason")
  lastStripeEventId      String?                  @map("last_stripe_event_id")
  lastEngineEventId      String?                  @map("last_engine_event_id")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([provider, updatedAt])
  @@map("billing_engine_states")
}

model EngineWebhookEvent {
  engineEventId      String                      @id @map("engine_event_id")
  provider           BillingEngineProvider
  eventType          String                      @map("event_type")
  payloadJson        Json                        @map("payload_json")
  rawBody            Bytes                       @map("raw_body")
  signatureHeader    String                      @map("signature_header")
  processingStatus   EngineWebhookProcessingStatus @default(received) @map("processing_status")
  processingAttempts Int                         @default(0) @map("processing_attempts")
  lastError          String?                     @map("last_error")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  @@index([provider, processingStatus, createdAt])
  @@map("engine_webhook_events")
}

// ============================================================================
// Admin & Audit
// ============================================================================

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String   @map("actor_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  meta        Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@map("audit_logs")
}
