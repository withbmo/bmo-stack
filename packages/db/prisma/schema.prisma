// Pytholit Database Schema
// Converted from SQLAlchemy models to Prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// User & Authentication
// ============================================================================

enum AdminLevel {
  owner
  operator
  viewer
}

model User {
  id             String  @id @default(uuid())
  email          String  @unique
  username       String  @unique
  firstName      String? @map("first_name")
  lastName       String? @map("last_name")
  bio            String?
  avatarUrl      String? @map("avatar_url")
  hashedPassword String? @map("hashed_password")

  // Status flags
  isActive        Boolean @default(true) @map("is_active")
  isEmailVerified Boolean @default(false) @map("is_email_verified")

  // External service IDs
  signupBonusGrantedAt DateTime? @map("signup_bonus_granted_at")
  novuSubscriberId     String?   @unique @map("novu_subscriber_id")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  projects       Project[]
  environments   Environment[]
  terminalTabs   TerminalTab[]
  deployJobs     DeployJob[]
  wizardBuilds   WizardBuild[]
  oauthAccounts  OAuthAccount[]
  sessions       Session[]
  accounts       Account[]
  paymentMethods UserPaymentMethod[]
  payments       Payment[]
  creditTopupRequests CreditTopupRequest[]
  creditLedgerEntries CreditLedgerEntry[]
  invoices       Invoice[]
  subscriptions  Subscription[]
  lagoEvents     LagoWebhookEvent[]
  auditLogs      AuditLog[]
  adminMembership         Admin?   @relation("AdminMembership")
  grantedAdminMemberships Admin[]  @relation("AdminGrantedBy")

  @@map("users")
}

model Admin {
  id              String     @id @default(uuid())
  userId          String     @unique @map("user_id")
  level           AdminLevel
  grantedByUserId String?    @map("granted_by_user_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user      User  @relation("AdminMembership", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("AdminGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@index([level])
  @@index([grantedByUserId])
  @@map("admins")
}

model OAuthAccount {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  provider     String // google, github
  accountId    String    @map("account_id")
  accountEmail String?   @map("account_email")
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, accountId])
  @@map("oauth_accounts")
}

// Better Auth session management
model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// Better Auth account table (replaces OAuthAccount for Better Auth)
model Account {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  accountId    String    @map("account_id")
  providerId   String    @map("provider_id") // "google" | "github" | "credentials"
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

// Better Auth verification table (email verification, password reset)
// Note: This table is auto-managed by Better Auth
model Verification {
  id         String   @id @default(uuid())
  identifier String // email or phone
  value      String   @unique // token/value
  expiresAt  DateTime @map("expiresAt")
  createdAt  DateTime @default(now()) @map("createdAt")
  updatedAt  DateTime @updatedAt @map("updatedAt")

  @@unique([identifier, value])
  @@map("verification")
}

model AuthLoginAttempt {
  id            String    @id @default(uuid())
  email         String    @unique
  failedAttempts Int      @default(0) @map("failed_attempts")
  firstFailedAt DateTime? @map("first_failed_at")
  lastFailedAt  DateTime? @map("last_failed_at")
  lockedUntil   DateTime? @map("locked_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([lockedUntil])
  @@map("auth_login_attempts")
}

model AuthOtpThrottle {
  id          String   @id @default(uuid())
  email       String
  ip          String
  action      String
  windowStart DateTime @map("window_start")
  windowSec   Int      @map("window_sec")
  attempts    Int      @default(0)
  lockedUntil DateTime? @map("locked_until")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([email, ip, action, windowStart, windowSec])
  @@index([email, ip, action, lockedUntil])
  @@map("auth_otp_throttles")
}

// ============================================================================
// Projects & Environments
// ============================================================================

model Project {
  id                String   @id @default(uuid())
  ownerId           String   @map("owner_id")
  name              String
  slug              String
  repoExportEnabled Boolean  @default(false) @map("repo_export_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deployJobs   DeployJob[]
  wizardBuilds WizardBuild[]

  @@unique([ownerId, slug])
  @@map("projects")
}

model Environment {
  id            String   @id @default(uuid())
  ownerId       String   @map("owner_id")
  projectId     String?  @map("project_id") // Nullable for backward compatibility
  envType       String   @map("name") // dev, staging, prod
  displayName   String   @map("display_name")
  tierPolicy    String   @default("free") @map("tier_policy") // free, pro, enterprise
  executionMode String   @default("managed") @map("execution_mode") // managed, byo_aws
  region        String   @default("us-east-1")
  visibility    String   @default("private") // public, private
  config        Json? // Environment configuration (JSONB)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deployJobs   DeployJob[]
  terminalTabs TerminalTab[]

  @@unique([ownerId, displayName])
  @@map("environments")
}

model TerminalTab {
  id            String @id @default(uuid())
  ownerId       String @map("owner_id")
  environmentId String @map("environment_id")

  title      String
  isActive   Boolean   @default(false) @map("is_active")
  archivedAt DateTime? @map("archived_at")

  transcript   String    @default("")
  lastSeq      BigInt    @default(0) @map("last_seq")
  lastActiveAt DateTime? @map("last_active_at")

  tmuxEnabled     Boolean   @default(false) @map("tmux_enabled")
  tmuxSessionName String?   @map("tmux_session_name")
  tmuxLastUsedAt  DateTime? @map("tmux_last_used_at")
  tmuxExpiresAt   DateTime? @map("tmux_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([ownerId, environmentId])
  @@index([environmentId])
  @@index([tmuxEnabled, tmuxExpiresAt])
  @@map("terminal_tabs")
}

model OrchestratorRegionConfig {
  id                  String   @id @default(uuid())
  region              String   @unique
  subnetIds           String[] @map("subnet_ids")
  securityGroupIds    String[] @map("security_group_ids")
  amiIdX86_64         String   @map("ami_id_x86_64")
  amiIdArm64          String   @map("ami_id_arm64")
  instanceProfileName String   @map("instance_profile_name")
  userDataBase64      String?  @map("user_data_base64")
  dynamodbTable       String   @default("EnvRouting") @map("dynamodb_table")
  envDomainSuffix     String   @default("envs.pytholit.dev") @map("env_domain_suffix")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("orchestrator_region_configs")
}

// ============================================================================
// Deployments
// ============================================================================

enum DeployJobStatus {
  queued
  running
  succeeded
  failed
  canceled
}

model DeployJob {
  id                    String          @id @default(uuid())
  projectId             String          @map("project_id")
  environmentId         String          @map("environment_id")
  triggeredByUserId     String?         @map("triggered_by_user_id")
  status                DeployJobStatus @default(queued)
  currentStep           String?         @map("current_step")
  steps                 Json // Array of deployment steps (JSONB)
  source                Json // Deployment source info (git, upload, template)
  executionModeSnapshot String          @map("execution_mode_snapshot")
  createdAt             DateTime        @default(now()) @map("created_at")
  startedAt             DateTime?       @map("started_at")
  finishedAt            DateTime?       @map("finished_at")

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  triggeredBy User?       @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@map("deploy_jobs")
}

// ============================================================================
// Wizard (Project generation)
// ============================================================================

model WizardBuild {
  id        String @id @default(uuid())
  ownerId   String @map("owner_id")
  projectId String @map("project_id")
  version   String // Wizard blueprint version (e.g. 2026.02.08)

  inputs   Json // Raw + default-applied inputs used to generate
  manifest Json // WizardManifest (files, metadata)
  lock     Json? // Optional BlueprintLock (debug/audit)

  createdAt DateTime @default(now()) @map("created_at")

  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([projectId])
  @@map("wizard_builds")
}

// ============================================================================
// Billing & Subscriptions
// ============================================================================

model Subscription {
  id                     String   @id @default(uuid())
  userId                 String   @map("user_id")
  planId                 String?  @map("plan_id")
  status                 String // active, canceled, past_due, unpaid, trialing
  billingInterval        String   @default("month") @map("billing_interval")
  featureAccessState     String   @default("enabled") @map("feature_access_state")
  externalSubscriptionId String   @unique @map("external_subscription_id")
  currentPeriodStart     DateTime @map("current_period_start")
  currentPeriodEnd       DateTime @map("current_period_end")
  cancelAtPeriodEnd      Boolean  @default(false) @map("cancel_at_period_end")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UserPaymentMethod {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  stripePaymentMethodId String   @unique @map("stripe_payment_method_id")
  type                  String // card, bank_account
  last4                 String
  brand                 String?
  expiryMonth           Int?     @map("expiry_month")
  expiryYear            Int?     @map("expiry_year")
  isDefault             Boolean  @default(false) @map("is_default")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_payment_methods")
}

model Payment {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  stripePaymentId String   @unique @map("stripe_payment_id")
  /// Amount in minor units (e.g. cents)
  amount          Int
  currency        String   @default("usd")
  status          String // pending, succeeded, failed, refunded
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model CreditTopupRequest {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  lagoInvoiceId String   @unique @map("lago_invoice_id")
  amountUsd     Int      @map("amount_usd")
  credits       Int
  status        String // pending, succeeded, failed
  grantedAt     DateTime? @map("granted_at")
  processedAt   DateTime? @map("processed_at")
  failureCode   String?  @map("failure_code")
  idempotencyKey String? @unique @map("idempotency_key")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("credit_topup_requests")
}

model CreditLedgerEntry {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  type         String
  deltaCredits Int      @map("delta_credits")
  balanceAfter Int      @map("balance_after")
  currency     String   @default("USD")
  referenceId  String?  @map("reference_id")
  reasonCode   String?  @map("reason_code")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, referenceId])
  @@map("credit_ledger_entries")
}

model Invoice {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  externalInvoiceId String    @unique @map("external_invoice_id")
  /// Amount in minor units (e.g. cents)
  amount          Int
  currency        String    @default("usd")
  status          String // draft, open, paid, void, uncollectible
  paidAt          DateTime? @map("paid_at")
  dueDate         DateTime? @map("due_date")
  invoiceUrl      String?   @map("invoice_url")
  pdfUrl          String?   @map("invoice_pdf")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model LagoWebhookEvent {
  /// Lago webhook event id
  id        String   @id
  type      String
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("lago_webhook_events")
}

// ============================================================================
// Admin & Audit
// ============================================================================

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String   @map("actor_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  meta        Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@map("audit_logs")
}
