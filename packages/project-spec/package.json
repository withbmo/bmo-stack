{
  "name": "@pytholit/project-spec",
  "version": "1.0.0",
  "description": "Spec-first project manifest parsing, validation, and planning for Pytholit",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test tests/project-spec.test.ts"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsup": "^8.3.5",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
