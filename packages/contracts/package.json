{
  "name": "@pytholit/contracts",
  "version": "1.0.0",
  "description": "Shared TypeScript types and contracts for Pytholit",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test:types": "tsd"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsd": "^0.31.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
