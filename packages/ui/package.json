{
  "name": "@pytholit/ui",
  "version": "1.0.0",
  "description": "Pytholit design system and shared UI components",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.mjs",
      "require": "./dist/ui.js"
    },
    "./blocks": {
      "types": "./dist/blocks.d.ts",
      "import": "./dist/blocks.mjs",
      "require": "./dist/blocks.js"
    },
    "./system": {
      "types": "./dist/system.d.ts",
      "import": "./dist/system.mjs",
      "require": "./dist/system.js"
    },
    "./styles": "./src/styles/index.css"
  },
  "scripts": {
    "build": "tsup src/index.ts src/ui.ts src/blocks.ts src/system.ts --format cjs,esm --dts --external react --external react-dom",
    "dev": "tsup src/index.ts src/ui.ts src/blocks.ts src/system.ts --format cjs,esm --dts --external react --external react-dom --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@pytholit/contracts": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.563.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.7.3",
    "recharts": "2.15.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@storybook/react": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.0",
    "jsdom": "^29.0.0",
    "storybook": "^10.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
