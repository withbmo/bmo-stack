{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@pytholit/ui/components": ["./src/components"],
      "@pytholit/ui/components/*": ["./src/components/*"],
      "@pytholit/ui/hooks": ["./src/hooks"],
      "@pytholit/ui/hooks/*": ["./src/hooks/*"],
      "@pytholit/ui/lib": ["./src/lib"],
      "@pytholit/ui/lib/*": ["./src/lib/*"],
      "@pytholit/ui/shadcn/ui": ["./src/shadcn/ui"],
      "@pytholit/ui/shadcn/ui/*": ["./src/shadcn/ui/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
