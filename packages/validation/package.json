{
  "name": "@pytholit/validation",
  "version": "1.0.0",
  "description": "Shared validation schemas (Zod & class-validator) for Pytholit",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.mjs",
      "require": "./dist/zod.js"
    },
    "./class-validator": {
      "types": "./dist/class-validator.d.ts",
      "import": "./dist/class-validator.mjs",
      "require": "./dist/class-validator.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/zod.ts src/class-validator.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/zod.ts src/class-validator.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@pytholit/contracts": "workspace:*",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "class-transformer": "^0.5.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "class-validator": "^0.14.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "class-validator": "^0.14.0"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "restricted"
  }
}
