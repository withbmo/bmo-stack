{
  "name": "pytholit-monorepo",
  "version": "2.0.0",
  "private": true,
  "description": "Pytholit monorepo - Next.js + Nest.js architecture",
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "dev": "turbo run dev --concurrency=20",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "check": "pnpm lint && pnpm type-check && pnpm build",
    "postinstall": "pnpm db:generate",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @pytholit/db db:generate",
    "db:migrate": "pnpm --filter @pytholit/db db:migrate",
    "db:studio": "pnpm --filter @pytholit/db prisma studio",
    "export:apps": "node scripts/export-apps-to-txt.mjs",
    "demo:build-images": "./scripts/build-and-push-demo-images.sh",
    "templates:generate": "pnpm --filter @pytholit/project-spec exec tsx ../../scripts/templates/generate-templates.ts",
    "templates:validate": "pnpm --filter @pytholit/project-spec exec tsx ../../scripts/templates/validate-templates.ts"
  },
  "devDependencies": {
    "@turbo/gen": "^2.3.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^3.2.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "pnpm": ">=9.0.0"
  }
}
